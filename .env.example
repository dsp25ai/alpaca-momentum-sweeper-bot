# ============================================================
# ALPACA MOMENTUM SWEEPER BOT - Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# --- Alpaca API Credentials ---
# Get these from https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# --- Trading Mode ---
# PAPER = safe simulation | LIVE = real money
TRADING_MODE=PAPER

# --- Alpaca Base URLs (auto-set by mode, but can override) ---
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Strategy Settings ---
# Minimum relative volume vs 20-day avg to qualify a stock
MIN_RVOL=2.0
# Minimum gap % at open to qualify (e.g. 3.0 = 3%)
MIN_GAP_PCT=3.0
# Opening Range minutes (e.g. 15 = first 15min candle)
ORB_MINUTES=15
# Max number of open positions at once
MAX_POSITIONS=5
# Dollar risk per trade (hard stop-loss distance x shares)
RISK_PER_TRADE=50
# Max total capital deployed at once ($)
MAX_CAPITAL=1000
# Take profit multiplier vs risk (e.g. 2.0 = 2R target)
TAKE_PROFIT_R=2.0
# Stop loss multiplier (1.0 = 1R)
STOP_LOSS_R=1.0

# --- Daily Risk Limits ---
# Max daily loss before bot stops trading ($)
MAX_DAILY_LOSS=150
# Max daily profit target (bot stops after hitting this) ($)
DAILY_PROFIT_TARGET=400
# Max trades per day
MAX_DAILY_TRADES=10

# --- Scanner Settings ---
# Scan interval in seconds
SCAN_INTERVAL=60
# Minimum stock price to consider
MIN_PRICE=5.0
# Maximum stock price to consider
MAX_PRICE=500.0
# Minimum average daily volume (shares)
MIN_AVG_VOLUME=500000

# --- Notifications ---
# Telegram (optional - leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhook (optional - leave blank to disable)
DISCORD_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# --- Database ---
DB_PATH=data/trades.db

# --- Timezone ---
TIMEZONE=America/New_York
